# Copy to .env (gitignored) for local dev overrides. Real environment variables win.
#
# agent holds NO secrets: the detection path needs no API key BY DESIGN, and no phase
# may add one (see .rules guardrail 5). This file documents non-secret AGENT_* config
# only. If you ever find yourself adding a credential here, the change is mis-scoped.

# --- Non-secret config (flags > env (AGENT_*) > file (TOML) > defaults) ---
# AGENT_DETECTOR=mock          # default detector for `agent check` (mock | secrets | pii | injection …)
# AGENT_LOG=warn               # error | warn | info | debug | trace (stderr; stdout is verdicts only)
# AGENT_ARTIFACT_DIR=          # where pulled/built artifacts are resolved from (default: target/detectors)

# --- Later phases (documented ahead of need) ---
# AGENT_REGISTRY=              # Phase 10: registry URL for `agent pull` (OSS tooling speaks to any registry)
# AGENT_ALLOW_UNSIGNED=false   # Phase 10: dev-only escape hatch for local unsigned artifacts
# AGENT_SERVE_ADDR=127.0.0.1:0 # Phase 12: sidecar bind — loopback-only by default, by design
